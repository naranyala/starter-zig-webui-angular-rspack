{
  "name": "angular-rspack-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:rspack": "bun run rspack build",
    "serve:rspack": "bun run rspack serve",
    "dev": "bun run rspack serve",
    "watch": "bun run rspack build --watch",
    "test": "bun test",
    "test:unit": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:report": "bunx playwright show-report",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:ci": "biome check --no-errors-on-unmatched --max-diagnostics=100",
    "lint:staged": "biome check --staged --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write && biome format --write",
    "generate-docs-manifest": "bun run scripts/generate-docs-manifest.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/ssr": "^21.2.5",
    "lucide-angular": "^1.0.0",
    "ngx-markdown": "^21.1.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "svg.js": "^2.7.1",
    "tslib": "^2.8.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2",
    "winbox": "^0.2.82",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.5",
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/language-service": "^21.2.6",
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@rspack/cli": "^1.7.10",
    "@rspack/core": "^1.7.10",
    "@types/node": "^25.5.0",
    "css-loader": "^7.1.4",
    "esbuild-loader": "^4.4.2",
    "html-rspack-plugin": "^6.1.8",
    "raw-loader": "^4.0.2",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "typescript": "~6.0.2"
  }
}
